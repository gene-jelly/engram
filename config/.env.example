# Engram — Environment Configuration
# Copy this to ~/.env and fill in your values.

# ═══════════════════════════════════════════════
# REQUIRED (core system)
# ═══════════════════════════════════════════════

# claude-mem worker (auto-set by the plugin, usually no change needed)
# CLAUDE_MEM_WORKER_PORT=37777
# CLAUDE_MEM_WORKER_HOST=127.0.0.1

# ═══════════════════════════════════════════════
# OPTIONAL — Neo4j (entity graph layer)
# ═══════════════════════════════════════════════

# NEO4J_URL=http://localhost:7474/db/neo4j/tx/commit
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=neo4j

# ═══════════════════════════════════════════════
# OPTIONAL — Honcho (strategic reasoning layer)
# ═══════════════════════════════════════════════

# HONCHO_API_KEY=your_honcho_api_key
# HONCHO_WORKSPACE_ID=claude-memory
# HONCHO_PEER_NAME=user

# ═══════════════════════════════════════════════
# OPTIONAL — A-Mem (Zettelkasten linking via Ollama)
# ═══════════════════════════════════════════════

# AMEM_PATH=~/.claude/tools/A-mem
# AMEM_LLM_MODEL=llama3.2:latest

# ═══════════════════════════════════════════════
# OPTIONAL — Paths (defaults work for most setups)
# ═══════════════════════════════════════════════

# ENGRAM_DB_PATH=~/.claude-mem/claude-mem.db
# ENGRAM_CHROMA_PATH=~/.claude-mem/vector-db
# ENGRAM_LOG_DIR=~/.claude-mem/logs
# ENGRAM_VAULT_DIR=~/Documents/vault
